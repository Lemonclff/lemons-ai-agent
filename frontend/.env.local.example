# ============================================================
# Lemon's AI Agent — 環境配置範例
# ============================================================
# 複製此檔為 .env.local 並填入你的值：
#   cp .env.local.example .env.local
#
# ⚠️  .env.local 已在 .gitignore — 絕對不要 commit 真實密鑰！

# ==================== Auth ====================
# 用於 HMAC token 簽章的密鑰（自訂任意字串）
ACCESS_PASSWORD=your-secret-here

# ==================== Database ====================
# PostgreSQL 連線字串
DATABASE_URL=postgresql://admin:***@localhost:5432/ai_dashboard_db

# ==================== LLM API (AI 資產分析) ====================
# Provider 優先級: NVIDIA > DeepSeek > OpenRouter > OpenAI
# 只要設定其中一個即可，系統自動偵測

# --- NVIDIA NIM (推薦, 支援 DeepSeek V4 Pro) ---
# 註冊: https://build.nvidia.com/deepseek-ai/deepseek-v4-pro
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro

# --- OpenRouter (備援) ---
# 註冊: https://openrouter.ai/keys
# OPENROUTER_API_KEY=***

# --- DeepSeek 官方 (備援) ---
# 註冊: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=***

# --- OpenAI (備援) ---
# 註冊: https://platform.openai.com/api-keys
# OPENAI_API_KEY=***

# --- LLM 通用設定 ---
LLM_TIMEOUT=180

# ==================== Langfuse (LLM Observability, 選用) ====================
# 註冊: https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
# LANGFUSE_SECRET_KEY=***
# LANGFUSE_HOST=https://cloud.langfuse.com
# NEXT_PUBLIC_LANGFUSE_URL=https://cloud.langfuse.com

# ==================== FRED API (總經數據, 選用) ====================
# 註冊: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your-fred-key-here

# ==================== 語音轉文字 (STT, 選用) ====================
# 說話者分離功能需要 HuggingFace Token
# 取得步驟:
#   1. https://huggingface.co/pyannote/speaker-diarization-3.1 → Accept 條款
#   2. https://huggingface.co/pyannote/segmentation-3.0 → Accept 條款
#   3. https://huggingface.co/settings/tokens → 建立 Read token
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Whisper Python 環境路徑（預設為 ~/.whisper-venv/bin/python3）
# WHISPER_PYTHON=/home/lemon/.whisper-venv/bin/python3

# ==================== Node ====================
NODE_ENV=development
