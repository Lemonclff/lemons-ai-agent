# ============================================================
# NexusQuant — Environment Variables (.env.example)
# ============================================================
# Copy this file to `.env` and fill in your actual values.
#   cp .env.example .env
#
# ⚠️  SECURITY WARNING:
# - `.env` is listed in `.gitignore` and MUST NEVER be committed.
# - `.env.example` is safe to commit — it contains no real secrets.
# - Rotate your API keys immediately if they ever leak to a public repo.
# - Use `git-secrets` or `detect-secrets` pre-commit hooks for extra safety.
# ============================================================

# ---- Langfuse (LLM Observability) ----
# Get your keys at: https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com
NEXT_PUBLIC_LANGFUSE_URL=https://cloud.langfuse.com

# ---- OpenAI / Anthropic / etc. (for LLM usage tracking) ----
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ---- Yahoo Finance (no key required, but can set user-agent) ----
# YF_USER_AGENT=Mozilla/5.0 ...

# ---- Optional: Database (if persisting reports to DB) ----
# DATABASE_URL=postgresql://user:password@localhost:5432/nexusquant

# ---- Optional: Notification Webhooks ----
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_CHAT_ID=-1001234567890

# ---- Node Environment ----
NODE_ENV=development
