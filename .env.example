# ============================================================
# Lemon's AI Agent — Environment Variables (.env.example)
# ============================================================
# Copy this file to `.env` and fill in your actual values.
#   cp .env.example .env
#
# ⚠️  SECURITY WARNING:
# - `.env` is listed in `.gitignore` and MUST NEVER be committed.
# - `.env.example` is safe to commit — it contains no real secrets.
# - Rotate your API keys immediately if they ever leak to a public repo.
# ============================================================

# ---- Database (dual backend support) ----
# SQLite (default, zero config):
#   Leave unset → auto-uses data/lemons.db
#
# PostgreSQL (production):
#   DATABASE_URL=postgresql://lemons:your_password@localhost:5432/lemons_agent
#
# Migration from SQLite → PostgreSQL:
#   1. python3 scripts/migrate_to_pg.py --export
#   2. export DATABASE_URL=postgresql://lemons:pass@localhost:5432/lemons_agent
#   3. python3 scripts/db_init.py
#   4. python3 scripts/migrate_to_pg.py --import
DATABASE_URL=

# ---- Langfuse (LLM Observability) ----
# Get your keys at: https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com
NEXT_PUBLIC_LANGFUSE_URL=https://cloud.langfuse.com

# ---- FRED API (Macro Economic Data) ----
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Node Environment ----
NODE_ENV=development
