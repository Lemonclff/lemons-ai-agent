# ============================================================
# NexusQuant — .gitignore
# ============================================================
# NEVER commit secrets, credentials, or environment variables.
# This file is your first line of defense against credential leaks.
# ============================================================

# ---- Secrets & Environment ----
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
credentials*.json
secrets*.yaml
secrets*.yml

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Build Output ----
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.venv/
venv/
env/
*.so

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Logs & Runtime ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Data (generated at runtime) ----
data/
!data/.gitkeep

# ---- Misc ----
.cache/
.tmp/
.temp/
coverage/
.nyc_output/
*.orig

# ---- Docker (if applicable) ----
docker-compose.override.yml

# ---- Terraform (if applicable) ----
.terraform/
*.tfstate
*.tfstate.*

# ---- OS ----
.DS_Store
Thumbs.db
